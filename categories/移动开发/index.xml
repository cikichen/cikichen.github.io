 &lt;th&gt;JetPack Compose&lt;/th&gt;
 &lt;th&gt;SwiftUI&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td&gt;支持平台&lt;/td&gt;
 &lt;td&gt;Android、iOS、Web、Desktop&lt;/td&gt;
 &lt;td&gt;Android&lt;/td&gt;
 &lt;td&gt;iOS、MacOS、iPadOS&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;开发语言&lt;/td&gt;
 &lt;td&gt;dart&lt;/td&gt;
 &lt;td&gt;kotlin&lt;/td&gt;
 &lt;td&gt;swift&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;性能&lt;/td&gt;
 &lt;td&gt;好&lt;/td&gt;
 &lt;td&gt;优&lt;/td&gt;
 &lt;td&gt;优&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;优点&lt;/td&gt;
 &lt;td&gt;跨平台&lt;/td&gt;
 &lt;td&gt;原生，简化UI构建&lt;/td&gt;
 &lt;td&gt;原生，简化UI构建&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
